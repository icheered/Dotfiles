[init]
	defaultBranch = main
[user]
	email = tjeerd992@gmail.com
	name = ICheered
[push]
    autoSetupRemote = true
[pull]
	rebase = true
[safe]
	directory = /etc/nixos/nixos-config
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
